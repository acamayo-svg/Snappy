# Copiar a .env y completar valores.

# Mercado Pago Checkout Pro
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
FRONTEND_URL=http://localhost:5173

# Opcional: validar webhooks con firma (Tus integraciones > Webhooks > clave secreta)
# MP_WEBHOOK_SECRET=

# Opcional: por defecto NO se envía payer.email en la preferencia (mejor para pruebas con TESTUSER).
# En producción, si quieres prellenar el correo del cliente: MP_PREFILL_PAYER_EMAIL=1
# MP_PREFILL_PAYER_EMAIL=1

# URL pública del API (Render suele definir RENDER_EXTERNAL_URL)
# URL_SERVIDOR=https://tu-api.onrender.com
